<Types>
    <Type>
        <Name>SolarWinds.WebHelpDesk.Session</Name>
        <Members>
            <ScriptProperty>
                <Name>IsExpired</Name>
                <GetScriptBlock>
                    $this.ExpirationDate -le ([DateTime]::Now)
                </GetScriptBlock>
            </ScriptProperty>
        </Members>
    </Type>
</Types>