<?xml version="1.0" encoding="utf-8"?>
<Types>
    <Type>
        <Name>SolarWinds.WebHelpDesk.CustomFieldDefinitions</Name>
        <Members>
            <ScriptProperty>
                <Name>Options</Name>
                <GetScriptBlock>
                    $this.optionsString -split ";"
                </GetScriptBlock>
            </ScriptProperty>
        </Members>
    </Type>
</Types>
